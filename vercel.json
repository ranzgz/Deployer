{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/admin",
      "destination": "/page/admin.html"
    },
    {
      "source": "/deploy",
      "destination": "/page/deploy.html"
    },
    {
      "source": "/docs",
      "destination": "/pages/docs.html"
    },
    {
      "source": "/preview",
      "destination": "/page/preview.html"
    },
    {
      "source": "/admin.js",
      "destination": "/js/admin.js"
    },
    {
      "source": "/preview.js",
      "destination": "/js/preview.js"
    },
    {
      "source": "/script.js",
      "destination": "/js/script.js"
    }
  ]
}
